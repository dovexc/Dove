# Copy to /opt/dove/server/.env on the VPS and fill in real values.
# Never commit the filled-in version.

DATABASE_URL=postgres://dove:CHANGE_ME@localhost:5432/dove

# Generate with: openssl rand -base64 32
# Required in production — without it the server falls back to a generated
# dev secret that invalidates all sessions on every restart.
DOVE_JWT_SECRET=CHANGE_ME

# Comma-separated emails to bootstrap as moderators on first register/login.
DOVE_ADMIN_EMAILS=you@example.com

DOVE_DEFAULT_QUOTA_BYTES=5368709120

# Cloudflare R2 (S3-compatible). Account ID and the API token's access/secret
# key come from the R2 dashboard; bucket name and public custom domain are
# whatever was set up when the bucket was created.
DOVE_R2_ACCOUNT_ID=CHANGE_ME
DOVE_R2_ACCESS_KEY_ID=CHANGE_ME
DOVE_R2_SECRET_ACCESS_KEY=CHANGE_ME
DOVE_R2_BUCKET=dove-assets
DOVE_R2_PUBLIC_BASE_URL=https://cdn.dovexc.com
